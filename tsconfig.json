{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "rootDir": "src",
    "outDir": "dist",

    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}